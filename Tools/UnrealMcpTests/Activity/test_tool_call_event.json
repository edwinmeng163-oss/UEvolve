    "method": "tools/call",
    "params": {
      "name": "unreal.editor_status",
      "arguments": {}
    }
  },
  "expectedActivityEvent": {
    "eventKind": "tool_call",
    "legacyEventType": "",
    "summary": "Called MCP tool unreal.editor_status: completed.",
    "payload": {
      "toolName": "unreal.editor_status",
      "handlerName": "unreal.editor_status",
      "riskLevel": "read_only",
      "argumentKeys": [],
      "isError": false,
      "textLength": "<number>",
      "hasStructuredContent": true,
      "durationMs": "<number>"
    }
  }
